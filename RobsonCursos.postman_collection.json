{
  "info": {
    "name": "Robson Cursos API",
    "description": "Coleção de testes para a API REST do sistema Robson Cursos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Cursos",
      "item": [
        {
          "name": "GET - Listar todos os cursos",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/cursos" }
          }
        },
        {
          "name": "GET - Buscar curso por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/cursos/1" }
          }
        },
        {
          "name": "GET - Buscar por categoria",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/cursos/categoria/Programação" }
          }
        },
        {
          "name": "GET - Buscar por nível",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/cursos/nivel/Avançado" }
          }
        },
        {
          "name": "POST - Cadastrar novo curso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:3001/cursos" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Flutter do Zero ao Avançado\",\n  \"descricao\": \"Aprenda a criar apps mobile com Flutter e Dart para iOS e Android.\",\n  \"dataInicio\": \"2025-06-01\",\n  \"duracao\": \"3 meses\",\n  \"cargaHoraria\": \"120 horas\",\n  \"nivel\": \"Intermediário\",\n  \"preco\": 899.90,\n  \"vagas\": 20,\n  \"categoria\": \"Mobile\",\n  \"imagem\": \"📱\",\n  \"instrutorId\": 1\n}"
            }
          }
        },
        {
