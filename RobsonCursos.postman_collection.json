            "url": { "raw": "http://localhost:3001/cursos/1" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Desenvolvimento Web Full Stack\",\n  \"descricao\": \"Aprenda a criar aplicações web completas do zero ao deploy.\",\n  \"dataInicio\": \"2025-02-10\",\n  \"duracao\": \"6 meses\",\n  \"cargaHoraria\": \"240 horas\",\n  \"nivel\": \"Iniciante\",\n  \"preco\": 1199.90,\n  \"vagas\": 35,\n  \"categoria\": \"Programação\",\n  \"imagem\": \"💻\",\n  \"instrutorId\": 1\n}"
